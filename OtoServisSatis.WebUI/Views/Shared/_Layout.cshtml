<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>@ViewData["Title"] - necdev</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OtoServisSatis.WebUI.styles.css" asp-append-version="true" />

    <!-- Prevent theme flash on page load -->
    <script>
        (function() {
            try {
                const storageKey = 'app-theme-preference';
                const saved = localStorage.getItem(storageKey);
                const theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3" id="mainNavbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">-_-</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Arac" asp-action="List">Tüm Araçlarımız</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Favorites" asp-action="Index">Favorilerim</a>
                        </li>
                    </ul>
                </div>
                <form class="col-12 col-lg-auto mb-3 mb-lg-0 me-lg-3" role="search" asp-action="Ara" asp-controller="Arac" method="get">
                    <input name="q" type="search" class="form-control" placeholder="Ara..." aria-label="Search">
                </form>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-sm theme-toggle-btn" type="button" title="Tema Değiştir">
                        <i class="bi bi-moon-stars"></i>
                    </button>
                    <div class="text-end">
                        @if (Context.User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Index" class="btn btn-primary me-2">
                                <i class="bi bi-person-vcard"></i> Hesabım
                            </a>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-primary">
                                <i class="bi bi-person-slash"></i> Oturumu Kapat
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary me-2">
                                <i class="bi bi-person-fill-check"></i> Giriş
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
                                <i class="bi bi-person-plus-fill"></i> Kaydol
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @Html.Raw(TempData["Message"])
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - OtoServisSatis.WebUI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Dinamik İkon Değişimi -->
    <script>
        window.addEventListener('themeChange', function(e) {
            const btn = document.querySelector('.theme-toggle-btn');
            if (btn) {
                const icon = btn.querySelector('i');
                if (icon) {
                    if (e.detail.theme === 'light') {
                        icon.className = 'bi bi-sun-fill';
                    } else {
                        icon.className = 'bi bi-moon-stars';
                    }
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>