<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>@ViewData["Title"] - necdev</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OtoServisSatis.WebUI.styles.css" asp-append-version="true" />

    <script>
        (function() {
            try {
                const storageKey = 'app-theme-preference';
                const saved = localStorage.getItem(storageKey);
                const theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
                document.documentElement.setAttribute('data-theme', theme);
                // Tercihi global bir değişkende tutarak aşağıda ikon atamasında kullanacağız
                window.__initialTheme = theme;
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'dark');
                window.__initialTheme = 'dark';
            }
        })();
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg py-3" id="mainNavbar">
            <div class="container-fluid crud-container d-flex align-items-center justify-content-between">

                <!-- Logo / Brand -->
                <a class="navbar-brand me-4" asp-area="" asp-controller="Home" asp-action="Index">-_-</a>

                <!-- Mobil Toggler (Sadece küçük ekranlarda) -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigasyon Linkleri ve Sağ Grup -->
                <div class="collapse navbar-collapse" id="navbarContent">
                    <!-- Sol Menü Linkleri (Dikeyde ortalanmış, tek satırda kalması garantilendi) -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-2 gap-lg-3">
                        <li class="nav-item">
                            <a class="nav-link text-nowrap py-1" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-nowrap py-1" asp-controller="Arac" asp-action="List">Tüm Araçlarımız</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-nowrap py-1" asp-controller="Favorites" asp-action="Index">Favorilerim</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-nowrap py-1" asp-controller="Randevu" asp-action="Index">Randevu Oluştur</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-nowrap py-1" asp-controller="Home" asp-action="Privacy">Gizlilik</a>
                        </li>
                    </ul>

                    <!-- Sağ Menü (Arama, Tema ve Hesap İşlemleri - Dikeyde Kusursuz Hizalı) -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-3 mt-3 mt-lg-0">

                        <!-- Minimal Arama Çubuğu -->
                        <form class="mb-0 w-100 w-lg-auto" role="search" asp-action="Ara" asp-controller="Arac" method="get">
                            <input name="q" type="search" class="form-control form-control-sm navbar-search" placeholder="Ara..." aria-label="Search">
                        </form>

                        <!-- İşlevsel Buton Grubu -->
                        <div class="d-flex align-items-center gap-2 w-100 w-lg-auto justify-content-between justify-content-lg-start">
                            <!-- Tema Değiştirme -->
                            <button class="theme-toggle-btn d-flex align-items-center justify-content-center" type="button" id="themeToggleBtn" title="Tema Değiştir">
                                <i class="bi bi-moon-stars"></i>
                            </button>

                            <!-- Kullanıcı Panel Butonları -->
                            <div class="d-flex gap-2">
                                @if (Context.User.Identity.IsAuthenticated)
                                {
                                    <a asp-controller="Account" asp-action="Index" class="btn btn-primary btn-sm px-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-person-vcard"></i> <span>Hesabım</span>
                                    </a>
                                    <a asp-controller="Account" asp-action="Logout" class="btn btn-secondary btn-sm px-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-person-slash"></i> <span>Çıkış</span>
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm px-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-person-fill-check"></i> Giriş
                                    </a>
                                    <a asp-controller="Account" asp-action="Register" class="btn btn-secondary btn-sm px-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-person-plus-fill"></i> Kaydol
                                    </a>
                                }
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="crud-container">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @Html.Raw(TempData["Message"])
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="crud-container border-top pt-2">
            &copy; 2026 - OtoServisSatis.WebUI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Gizlilik Politikası</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function() {
            const btn = document.getElementById('themeToggleBtn');
            if (btn) {
                const icon = btn.querySelector('i');
                if (icon && window.__initialTheme) {
                    icon.className = window.__initialTheme === 'light' ? 'bi bi-sun-fill' : 'bi bi-moon-stars';
                }
            }
        })();

        window.addEventListener('themeChange', function(e) {
            const btn = document.getElementById('themeToggleBtn');
            if (btn) {
                const icon = btn.querySelector('i');
                if (icon) {
                    icon.className = e.detail.theme === 'light' ? 'bi bi-sun-fill' : 'bi bi-moon-stars';
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>