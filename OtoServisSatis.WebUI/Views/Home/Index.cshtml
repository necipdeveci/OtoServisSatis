@model HomePageViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="crud-container">
    @if (Model.Sliders != null && Model.Sliders.Any())
    {
        <div class="carousel-section">
            <div id="carouselExampleCaptions" class="carousel slide carousel-fade" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Sliders.Count; i++)
                    {
                        <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
                    }
                </div>

                <div class="carousel-inner">
                    @foreach (var item in Model.Sliders)
                    {
                        <div class="carousel-item @(item == Model.Sliders.FirstOrDefault() ? "active" : "")">
                            <img src="/Img/Slider/@item.Resim" class="carousel-image" alt="@item.Baslik">
                            <div class="carousel-caption">
                                <h2 class="carousel-title">@item.Baslik</h2>
                                <p class="carousel-description">@item.Aciklama</p>
                            </div>
                        </div>
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    }

    <section class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">Hoş Geldiniz</h1>
            <p class="hero-subtitle">
                <a href="https://learn.microsoft.com/aspnet/core" class="hero-link">
                    ASP.NET Core ile web uygulamaları geliştirme hakkında daha fazla bilgi edinin
                </a>
            </p>
        </div>
    </section>

    <section class="products-section">
        <div class="products-grid">
            <partial name="_PartialAracView" model="Model.Araclar" />
        </div>
    </section>
</div>