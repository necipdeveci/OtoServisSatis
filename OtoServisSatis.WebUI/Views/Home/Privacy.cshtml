@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="crud-container">
    <header class="crud-page-header">
        <h1 class="crud-page-title">@ViewData["Title"]</h1>
        <p class="crud-page-description">Sitemizin gizlilik politikaları ve veri güvenliği standartları.</p>
    </header>

    <hr class="crud-divider" />

    <div class="crud-detail-card">
        <div class="crud-detail-header">
            <h4 class="crud-detail-title">Kullanım Koşulları ve Veri Güvenliği</h4>
        </div>
        <div class="crud-form-section">
            <p class="crud-detail-value">
                Use this page to detail your site's privacy policy. Sitenizin yasal gereksinimlerine göre bu alanı
                düzenleyebilir, kullanıcı veri işleme süreçlerini belirtebilirsiniz. Monokrom tasarım dili sayesinde
                uzun metinler bu yapıda oldukça okunaklı ve profesyonel görünecektir.
            </p>
        </div>
    </div>
</div>