@model CarDetailViewModel
@{
    ViewData["Title"] = Model.Arac.Marka.Adi + " " + Model.Arac.Modeli + " " + Model.Arac.KasaTipi;
}

<section class="py-5">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row gx-4 gx-lg-5 align-items-center">
            <!-- Carousel Section -->
            <div class="col-md-6">
                <div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel" style="min-height: 500px; display: flex; flex-direction: column;">
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
                    </div>
                    <div class="carousel-inner" style="flex: 1; display: flex; align-items: center; overflow: hidden; border-radius: 0.5rem;">
                        <div class="carousel-item active" style="width: 100%; height: 100%;">
                            <img src="/Img/Cars/@Model.Arac.Resim1" class="d-block w-100 h-100" alt="@Model.Arac.Modeli" style="object-fit: cover;">
                        </div>
                        <div class="carousel-item" style="width: 100%; height: 100%;">
                            <img src="/Img/Cars/@Model.Arac.Resim2" class="d-block w-100 h-100" alt="@Model.Arac.Modeli" style="object-fit: cover;">
                        </div>
                        <div class="carousel-item" style="width: 100%; height: 100%;">
                            <img src="/Img/Cars/@Model.Arac.Resim3" class="d-block w-100 h-100" alt="@Model.Arac.Modeli" style="object-fit: cover;">
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>

            <!-- Product Details Section -->
            <div class="col-md-6" style="display: flex; flex-direction: column; justify-content: center; min-height: 500px;">
                <div class="small mb-1"></div>
                <h1 class="display-5 fw-bolder">@ViewData["Title"]</h1>

                <!-- Fiyat -->
                <div class="fs-5 mb-3">
                    <span class="fw-bold">Fiyat: </span>
                    <span>₺@Model.Arac.Fiyati.ToString("N0")</span>
                    <span class="text-decoration-line-through text-muted ms-2">₺@((Model.Arac.Fiyati * 1.3m).ToString("N0"))</span>
                </div>

                <!-- Renk -->
                <div class="fs-5 mb-3">
                    <span class="fw-bold">Renk: </span>
                    <span>@Model.Arac.Renk</span>
                </div>

                <!-- Model Yılı -->
                <div class="fs-5 mb-3">
                    <span class="fw-bold">Model Yılı: </span>
                    <span>@Model.Arac.ModelYili</span>
                </div>

                <!-- Açıklama -->
                <p class="lead mb-4">@Model.Arac.Notlar</p>

                <!-- İşlem Butonları -->
                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-shrink-0" type="button" data-bs-toggle="modal" data-bs-target="#exampleModal">
                        <i class="bi bi-chat-dots me-1"></i>
                        Bilgi Al
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal -->
<partial name="Musteri" model="Model.Musteri" />

<style>
    /* Carousel kontroller tema desteği */
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1);
    }

    html[data-theme="light"] .carousel-control-prev-icon,
    html[data-theme="light"] .carousel-control-next-icon {
        filter: invert(0);
    }

    /* Carousel göstergeleri tema desteği */
    .carousel-indicators button {
        background-color: rgba(255, 255, 255, 0.5);
    }

    html[data-theme="light"] .carousel-indicators button {
        background-color: rgba(0, 0, 0, 0.3);
    }

    .carousel-indicators button.active {
        background-color: rgba(255, 255, 255, 0.9);
    }

    html[data-theme="light"] .carousel-indicators button.active {
        background-color: rgba(0, 0, 0, 0.7);
    }
</style>