@model CustomerLoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="crud-container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="crud-form-card">
                <div class="text-center mb-4">
                    <h2 class="fw-bold m-0 text-uppercase tracking-wider">Giriş Yap</h2>
                    <p class="text-muted small mt-2">Hesabınıza erişmek için bilgilerinizi girin.</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="crud-validation-summary text-danger"></div>

                    <div class="crud-form-group mb-3">
                        <label asp-for="Email" class="mb-2"></label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Örn: name@example.com" autofocus />
                        <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                    </div>

                    <div class="crud-form-group mb-4">
                        <label asp-for="Sifre" class="mb-2"></label>
                        <input asp-for="Sifre" type="password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Sifre" class="text-danger small mt-1"></span>
                    </div>

                    <div class="crud-form-actions p-0 border-0 m-0">
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-medium">Oturum Aç</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>