@model OtoServisSatis.Entities.Marka

@{
    ViewData["Title"] = "Marka Düzenle";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Marka Düzenle</h1>
        <p class="crud-page-description">Marka bilgilerini güncelleyin</p>
    </div>

    <form asp-action="Edit" class="crud-form-card">
        <div asp-validation-summary="All" class="crud-validation-summary"></div>

        <input type="hidden" asp-for="Id" />

        <!-- Marka Bilgileri Bölümü -->
        <div class="crud-form-section">
            <h3 class="crud-form-section-title">Marka Bilgileri</h3>

            <div class="crud-form-row">
                <div class="crud-form-group">
                    <label asp-for="Adi">Marka Adı <span class="required">*</span></label>
                    <input asp-for="Adi" class="form-control" />
                    <span asp-validation-for="Adi" class="crud-validation-error"></span>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="crud-form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Kaydet
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}