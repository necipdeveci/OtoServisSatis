@model OtoServisSatis.Entities.Marka

@{
    ViewData["Title"] = "Marka Sil";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Marka Sil</h1>
        <p class="crud-page-description">Bu işlem geri alınamaz</p>
    </div>

    <div class="crud-detail-card">
        <div class="crud-detail-header">
            <h2 class="crud-detail-title">Silmek istediğiniz marka bilgileri</h2>
        </div>

        <div class="crud-confirmation-alert">
            <h4><i class="fas fa-exclamation-triangle"></i> Uyarı</h4>
            <p>Bu marka silinecek. Bu işlem geri alınamaz ve markayla ilişkili tüm araçlar da etkilenecektir.</p>
        </div>

        <div class="crud-detail-grid">
            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Adi)</div>
                <div class="crud-detail-value">
                    <strong>@Html.DisplayFor(model => model.Adi)</strong>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="crud-confirmation-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Sil
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> İptal
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}