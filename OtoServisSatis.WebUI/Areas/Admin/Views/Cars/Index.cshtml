@model IEnumerable<OtoServisSatis.Entities.Arac>

@{
    ViewData["Title"] = "Araçlar";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Araçlar</h1>
        <p class="crud-page-description">Satış için mevcut araçları yönetin</p>
    </div>

    <div class="crud-table-wrapper">
        <div class="crud-table-header">
            <h2 class="crud-table-title">Araç Listesi</h2>
            <div class="crud-table-actions">
                <a class="btn btn-primary" asp-action="Create">
                    <i class="fas fa-plus"></i> Yeni Araç
                </a>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="crud-table table">
                    <thead>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Plaka)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Marka)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Modeli)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().ModelYili)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Renk)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().KasaTipi)</th>
                            <th class="crud-table-col-price">@Html.DisplayNameFor(model => model.FirstOrDefault().Fiyati)</th>
                            <th class="crud-table-col-status">Durum</th>
                            <th class="crud-table-col-image">Resim</th>
                            <th class="crud-table-col-actions">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@Html.DisplayFor(modelItem => item.Plaka)</strong></td>
                                <td>@Html.DisplayFor(modelItem => item.Marka.Adi)</td>
                                <td>@Html.DisplayFor(modelItem => item.Modeli)</td>
                                <td>@Html.DisplayFor(modelItem => item.ModelYili)</td>
                                <td>@Html.DisplayFor(modelItem => item.Renk)</td>
                                <td>@Html.DisplayFor(modelItem => item.KasaTipi)</td>
                                <td class="crud-table-col-price"><strong>₺@item.Fiyati.ToString("N0")</strong></td>
                                <td>
                                    @if (item.SatistaMi)
                                    {
                                        <span class="badge bg-success">Satışta</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Satış Dışı</span>
                                    }
                                </td>
                                <td class="crud-table-col-image">
                                    @if (!string.IsNullOrEmpty(item.Resim1))
                                    {
                                        <img src="/Img/Cars/@item.Resim1" alt="@item.Plaka" />
                                    }
                                </td>
                                <td>
                                    <div class="crud-table-actions-cell">
                                        <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Id" title="Düzenle">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="crud-empty-state">
                <div class="crud-empty-state-icon">📭</div>
                <h3 class="crud-empty-state-title">Araç Bulunamadı</h3>
                <p class="crud-empty-state-description">Henüz hiç araç eklenmemiş. Başlamak için yeni bir araç ekleyin.</p>
                <a class="btn btn-primary crud-empty-state-action" asp-action="Create">
                    <i class="fas fa-plus"></i> İlk Araçı Ekle
                </a>
            </div>
        }
    </div>
</div>