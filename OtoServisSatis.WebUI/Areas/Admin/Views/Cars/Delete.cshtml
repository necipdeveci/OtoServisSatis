@model OtoServisSatis.Entities.Arac

@{
    ViewData["Title"] = "Araç Sil";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Araç Sil</h1>
        <p class="crud-page-description">Bu işlem geri alınamaz</p>
    </div>

    <div class="crud-detail-card">
        <div class="crud-detail-header">
            <h2 class="crud-detail-title">Silmek istediğiniz araç bilgileri</h2>
        </div>

        <div class="crud-confirmation-alert">
            <h4><i class="fas fa-exclamation-triangle"></i> Uyarı</h4>
            <p>Bu araç silinecek. Bu işlem geri alınamaz ve araçla ilişkili tüm veriler de silinecektir.</p>
        </div>

        <div class="crud-detail-grid">
            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Plaka)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Plaka)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Marka)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Marka.Adi)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Modeli)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Modeli)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.ModelYili)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.ModelYili)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Renk)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Renk)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.KasaTipi)</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.KasaTipi)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Fiyati)</div>
                <div class="crud-detail-value">₺@Model.Fiyati.ToString("N0")</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.SatistaMi)</div>
                <div class="crud-detail-value">@(Model.SatistaMi ? "Evet" : "Hayır")</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notlar))
            {
                <div class="crud-detail-item">
                    <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Notlar)</div>
                    <div class="crud-detail-value">@Html.DisplayFor(model => model.Notlar)</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Resim1))
            {
                <div class="crud-detail-item">
                    <div class="crud-detail-label">Resim</div>
                    <div class="crud-detail-image">
                        <img src="/Img/Cars/@Model.Resim1" alt="Araç Resmi" />
                    </div>
                </div>
            }
        </div>

        <form asp-action="Delete" class="crud-confirmation-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Sil
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> İptal
            </a>
        </form>
    </div>
</div>