@{
    ViewData["Title"] = "Admin Ana Ekran";
}

<div class="container-fluid px-4">
    <h1 class="h3 mb-4 mt-4">Admin Ana Ekran</h1>

    <!-- Stats Cards Row -->
    <div class="row g-3">
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-4 h-100" style="border-start-color: var(--dark-primary) !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="text-muted mb-2 small">Toplam Müşteri</h6>
                            <h3 class="mb-0">1,234</h3>
                            <small class="text-muted">Tümü</small>
                        </div>
                        <div class="text-muted">
                            <i class="fas fa-users fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <a href="#" class="small text-decoration-none d-flex align-items-center">
                        Detayları Gör
                        <i class="fas fa-angle-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-4 h-100" style="border-start-color: var(--dark-secondary) !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="text-muted mb-2 small">Bu Ay Gelir</h6>
                            <h3 class="mb-0">₺45,230</h3>
                            <small class="text-muted">+12.5% artış</small>
                        </div>
                        <div class="text-muted">
                            <i class="fas fa-chart-line fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <a href="#" class="small text-decoration-none d-flex align-items-center">
                        Detayları Gör
                        <i class="fas fa-angle-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-4 h-100" style="border-start-color: var(--dark-primary) !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="text-muted mb-2 small">Aktif Siparişler</h6>
                            <h3 class="mb-0">28</h3>
                            <small class="text-muted">İşlemde</small>
                        </div>
                        <div class="text-muted">
                            <i class="fas fa-boxes fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <a href="#" class="small text-decoration-none d-flex align-items-center">
                        Detayları Gör
                        <i class="fas fa-angle-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-4 h-100" style="border-start-color: var(--dark-secondary) !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="text-muted mb-2 small">Ortalama Rating</h6>
                            <h3 class="mb-0">4.8/5.0</h3>
                            <small class="text-muted">120 değerlendirme</small>
                        </div>
                        <div class="text-muted">
                            <i class="fas fa-star fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <a href="#" class="small text-decoration-none d-flex align-items-center">
                        Detayları Gör
                        <i class="fas fa-angle-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mt-1">
        <div class="col-xl-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center">
                    <i class="fas fa-chart-area me-2"></i>
                    <span>Alan Grafik</span>
                </div>
                <div class="card-body position-relative" style="height: 350px;">
                    <canvas id="myAreaChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center">
                    <i class="fas fa-chart-bar me-2"></i>
                    <span>Bar Grafik</span>
                </div>
                <div class="card-body position-relative" style="height: 350px;">
                    <canvas id="myBarChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Row -->
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center">
                    <i class="fas fa-table me-2"></i>
                    <span>Son İşlemler</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="datatablesSimple" class="table table-hover table-sm">
                            <thead>
                                <tr>
                                    <th class="text-muted">Adı</th>
                                    <th class="text-muted">Pozisyon</th>
                                    <th class="text-muted">Ofis</th>
                                    <th class="text-muted">Yaş</th>
                                    <th class="text-muted">Başlama Tarihi</th>
                                    <th class="text-muted">Maaş</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Tiger Nixon</td>
                                    <td>Sistem Mimarı</td>
                                    <td>Edinburgh</td>
                                    <td>61</td>
                                    <td>2011/04/25</td>
                                    <td>$320,800</td>
                                </tr>
                                <tr>
                                    <td>Garrett Winters</td>
                                    <td>Muhasebeci</td>
                                    <td>Tokyo</td>
                                    <td>63</td>
                                    <td>2011/07/25</td>
                                    <td>$170,750</td>
                                </tr>
                                <tr>
                                    <td>Ashton Cox</td>
                                    <td>Junior Teknik Yazar</td>
                                    <td>San Francisco</td>
                                    <td>66</td>
                                    <td>2009/01/12</td>
                                    <td>$86,000</td>
                                </tr>
                                <tr>
                                    <td>Cedric Kelly</td>
                                    <td>Kıdemli Javascript Geliştirici</td>
                                    <td>Edinburgh</td>
                                    <td>22</td>
                                    <td>2012/03/29</td>
                                    <td>$433,060</td>
                                </tr>
                                <tr>
                                    <td>Airi Satou</td>
                                    <td>Muhasebeci</td>
                                    <td>Tokyo</td>
                                    <td>33</td>
                                    <td>2008/11/28</td>
                                    <td>$162,700</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        // Tema rengini al
        function getThemeColor(variable) {
            return getComputedStyle(document.documentElement).getPropertyValue(variable).trim();
        }

        // Area Chart
        const ctxArea = document.getElementById('myAreaChart');
        if (ctxArea) {
            new Chart(ctxArea, {
                type: 'line',
                data: {
                    labels: ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz'],
                    datasets: [{
                        label: 'Aylık Gelir (₺)',
                        data: [12000, 15000, 10000, 16000, 18000, 14000, 20000],
                        borderColor: getThemeColor('--dark-primary'),
                        backgroundColor: getThemeColor('--dark-primary') + '15',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 2,
                        pointBackgroundColor: getThemeColor('--dark-primary'),
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            labels: {
                                color: getThemeColor('--dark-text'),
                                padding: 15,
                                font: { size: 12 }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: { color: getThemeColor('--dark-text-muted') },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        x: {
                            ticks: { color: getThemeColor('--dark-text-muted') },
                            grid: { display: false }
                        }
                    }
                }
            });
        }

        // Bar Chart
        const ctxBar = document.getElementById('myBarChart');
        if (ctxBar) {
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz'],
                    datasets: [{
                        label: 'Satış Sayısı',
                        data: [50, 75, 60, 85, 90, 70, 95],
                        backgroundColor: getThemeColor('--dark-primary') + 'CC',
                        borderColor: getThemeColor('--dark-primary'),
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            labels: {
                                color: getThemeColor('--dark-text'),
                                padding: 15,
                                font: { size: 12 }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: { color: getThemeColor('--dark-text-muted') },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        x: {
                            ticks: { color: getThemeColor('--dark-text-muted') },
                            grid: { display: false }
                        }
                    }
                }
            });
        }
    </script>
}