@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        function getThemeColor(variable) {
            let color = getComputedStyle(document.documentElement).getPropertyValue(variable).trim();
            return color !== "" ? color : '#0d6efd';
        }

        const charts = {};

        async function loadChart(url, canvasId, chartType, labelText) {
            try {
                const response = await fetch(url);
                const data = await response.json();

                const labels = data.map(x => x.etiket);
                const values = data.map(x => x.deger);

                const ctx = document.getElementById(canvasId);
                if (!ctx) return;

                if (charts[canvasId]) {
                    charts[canvasId].destroy();
                }

                const primaryColor = getThemeColor('--dark-primary');
                const bgColor = chartType === 'line' ? primaryColor + '15' : primaryColor + 'CC';

                charts[canvasId] = new Chart(ctx, {
                    type: chartType,
                    data: {
                        labels: labels,
                        datasets: [{
                            label: labelText,
                            data: values,
                            borderColor: primaryColor,
                            backgroundColor: bgColor,
                            fill: chartType === 'line',
                            tension: 0.4,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: true }
                        }
                    }
                });
            } catch (error) {
                console.error(canvasId + ' yüklenirken hata:', error);
            }
        }

        function updateAylikSatis() {
            const ay = document.getElementById('aylikSatisAy').value;
            loadChart(`/Admin/Main/GetAylikSatis?ay=${ay}`, 'aylikSatisChart', 'line', 'Aylık Satış Dağılımı');
        }

        function updateGunlukSatis() {
            const tarih = document.getElementById('gunlukSatisTarih').value;
            loadChart(`/Admin/Main/GetGunlukSatis?tarih=${tarih}`, 'gunlukSatisChart', 'bar', 'Marka Satış Adetleri');
        }

        function updateServisAylik() {
            const ay = document.getElementById('servisAylikAy').value;
            loadChart(`/Admin/Main/GetServisAylik?ay=${ay}`, 'servisAylikChart', 'bar', 'Aylık Servise Gelen Araçlar');
        }

        function updateServisGunluk() {
            const tarih = document.getElementById('servisGunlukTarih').value;
            loadChart(`/Admin/Main/GetServisGunluk?tarih=${tarih}`, 'servisGunlukChart', 'bar', 'Günlük Servise Gelen Araçlar');
        }

        function updateSatisMarkaModel() {
            const marka = document.getElementById('satisMarkaSeçim').value;
            const ay = document.getElementById('satisMarkaAy').value;
            if(marka) {
                loadChart(`/Admin/Main/GetSatisMarkaModel?marka=${marka}&ay=${ay}`, 'satisMarkaModelChart', 'bar', `${marka} - Model Satışları`);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateAylikSatis();
            updateGunlukSatis();
            updateServisAylik();
            updateServisGunluk();
        });
    </script>
}