@model OtoServisSatis.Entities.Kullanici

@{
    ViewData["Title"] = "Kullanıcı Sil";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Kullanıcıyı Sil</h1>
        <p class="crud-page-description">Aşağıdaki kullanıcı kaydı kalıcı olarak sistemden kaldırılacaktır.</p>
    </div>

    <hr class="crud-divider" />

    <div class="crud-confirmation-alert">
        <h4><i class="fas fa-exclamation-triangle"></i> Dikkat!</h4>
        <p>Bu işlemi geri alamazsınız. Kullanıcıyı silmek istediğinize emin misiniz?</p>
    </div>

    <div class="crud-detail-card">
        <div class="crud-detail-header">
            <h5 class="crud-detail-title">Kullanıcı Profil Detayları</h5>
        </div>

        <div class="crud-detail-grid">
            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Adi):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Adi)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Soyadi):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Soyadi)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Email):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Email)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Telefon):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Telefon)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.KullaniciAdi):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.KullaniciAdi)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Sifre):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Sifre)</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.AktifMi):</div>
                <div class="crud-detail-value">@(Model.AktifMi ? "Evet" : "Hayır")</div>
            </div>

            <div class="crud-detail-item">
                <div class="crud-detail-label">@Html.DisplayNameFor(model => model.Rol):</div>
                <div class="crud-detail-value">@Html.DisplayFor(model => model.Rol.Adi)</div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="crud-confirmation-actions m-0 p-0" style="border:none;">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt"></i> Kullanıcıyı Sil
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-undo"></i> İptal Et ve Dön
                </a>
            </div>
        </form>
    </div>
</div>