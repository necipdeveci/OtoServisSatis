@model OtoServisSatis.Entities.Kullanici

@{
    ViewData["Title"] = "Kullanıcı Ekle";
}

<div class="admin-form-container">
    <h1 class="admin-form-title">Yeni Kullanıcı Ekle</h1>

    <div class="admin-form-card">
        <form asp-action="Create" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="admin-validation-summary"></div>

            <!-- Kişisel Bilgiler Başlığı -->
            <h5 class="mt-3 mb-3" style="font-weight: 600; color: var(--bs-primary);">
                <i class="fas fa-user"></i> Kişisel Bilgiler
            </h5>

            <!-- Ad -->
            <div class="admin-form-group">
                <label asp-for="Adi" class="control-label">Ad *</label>
                <input asp-for="Adi" class="form-control" placeholder="Kullanıcı adı" />
                <span asp-validation-for="Adi" class="admin-validation-error"></span>
            </div>

            <!-- Soyadı -->
            <div class="admin-form-group">
                <label asp-for="Soyadi" class="control-label">Soyadı *</label>
                <input asp-for="Soyadi" class="form-control" placeholder="Kullanıcı soyadı" />
                <span asp-validation-for="Soyadi" class="admin-validation-error"></span>
            </div>

            <!-- Email -->
            <div class="admin-form-group">
                <label asp-for="Email" class="control-label">E-Mail *</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="kullanici@example.com" />
                <span asp-validation-for="Email" class="admin-validation-error"></span>
            </div>

            <!-- Telefon -->
            <div class="admin-form-group">
                <label asp-for="Telefon" class="control-label">Telefon</label>
                <input asp-for="Telefon" class="form-control" placeholder="0555 123 4567" />
                <span asp-validation-for="Telefon" class="admin-validation-error"></span>
            </div>

            <!-- Hesap Bilgileri Başlığı -->
            <h5 class="mt-4 mb-3" style="font-weight: 600; color: var(--bs-primary);">
                <i class="fas fa-lock"></i> Hesap Bilgileri
            </h5>

            <!-- Kullanıcı Adı -->
            <div class="admin-form-group">
                <label asp-for="KullaniciAdi" class="control-label">Kullanıcı Adı *</label>
                <input asp-for="KullaniciAdi" class="form-control" placeholder="Giriş için kullanılacak ad" />
                <span asp-validation-for="KullaniciAdi" class="admin-validation-error"></span>
            </div>

            <!-- Şifre -->
            <div class="admin-form-group">
                <label asp-for="Sifre" class="control-label">Şifre *</label>
                <input asp-for="Sifre" class="form-control" type="password" placeholder="Güvenli bir şifre girin" />
                <small class="text-muted d-block mt-1">En az 8 karakter, özel karakter içermeli</small>
                <span asp-validation-for="Sifre" class="admin-validation-error"></span>
            </div>

            <!-- Rol -->
            <div class="admin-form-group">
                <label asp-for="RolId" class="control-label">Rol *</label>
                <select asp-for="RolId" class="form-select" asp-items="ViewBag.RolId">
                    <option value="">-- Rol Seçiniz --</option>
                </select>
                <span asp-validation-for="RolId" class="admin-validation-error"></span>
            </div>

            <!-- Aktif Mi -->
            <div class="admin-form-group">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="AktifMi" />
                    <label class="form-check-label" for="AktifMi">
                        @Html.DisplayNameFor(model => model.AktifMi)
                    </label>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Kullanıcı Ekle
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}