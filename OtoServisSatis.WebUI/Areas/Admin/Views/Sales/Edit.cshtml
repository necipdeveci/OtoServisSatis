@model OtoServisSatis.Entities.Satis

@{
    ViewData["Title"] = "Satış Kaydını Düzenle";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Satış Kaydını Düzenle</h1>
        <p class="crud-page-description">Satış kaydı bilgilerini güncelleyin</p>
        <div class="crud-divider"></div>
    </div>

    <div class="crud-form-card">
        <form asp-action="Edit" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="crud-validation-summary"></div>
            
            <input type="hidden" asp-for="Id" />

            <!-- Satış Bilgileri Bölümü -->
            <div class="crud-form-section">
                <h5 class="crud-form-section-title">
                    <i class="fas fa-shopping-cart"></i> Satış Bilgileri
                </h5>

                <div class="crud-form-row">
                    <div class="crud-form-group">
                        <label asp-for="AracId" class="control-label">
                            Araç
                            <span class="required">*</span>
                        </label>
                        <select asp-for="AracId" class="form-select" asp-items="ViewBag.AracId"></select>
                        <span asp-validation-for="AracId" class="crud-validation-error"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="MusteriId" class="control-label">
                            Müşteri
                            <span class="required">*</span>
                        </label>
                        <select asp-for="MusteriId" class="form-select" asp-items="ViewBag.MusteriId"></select>
                        <span asp-validation-for="MusteriId" class="crud-validation-error"></span>
                    </div>
                </div>

                <div class="crud-form-row">
                    <div class="crud-form-group">
                        <label asp-for="SatisFiyati" class="control-label">
                            Satış Fiyatı (₺)
                            <span class="required">*</span>
                        </label>
                        <input asp-for="SatisFiyati" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="SatisFiyati" class="crud-validation-error"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="SatisTarihi" class="control-label">
                            Satış Tarihi
                            <span class="required">*</span>
                        </label>
                        <input asp-for="SatisTarihi" class="form-control" type="datetime-local" />
                        <span asp-validation-for="SatisTarihi" class="crud-validation-error"></span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="crud-form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Değişiklikleri Kaydet
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}