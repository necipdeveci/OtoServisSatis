@model OtoServisSatis.Entities.Satis

@{
    ViewData["Title"] = "Satış Kaydını Sil";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Satış Kaydını Sil</h1>
        <p class="crud-page-description">Bu işlem geri alınamaz</p>
        <div class="crud-divider"></div>
    </div>

    <div class="crud-detail-card">
        <div class="crud-confirmation-alert">
            <h4><i class="fas fa-exclamation-triangle"></i> Onay Gerekli</h4>
            <p>Bu satış kaydını silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
        </div>

        <div class="crud-detail-header">
            <h5 class="crud-detail-title">Silinecek Kayıt Bilgileri</h5>
        </div>

        <div class="crud-detail-grid">
            <div class="crud-detail-item">
                <span class="crud-detail-label">Satış Tarihi:</span>
                <span class="crud-detail-value">@Model.SatisTarihi.ToString("dd.MM.yyyy HH:mm")</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Satış Fiyatı:</span>
                <span class="crud-detail-value">₺@Model.SatisFiyati.ToString("N2")</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Araç Bilgisi:</span>
                <span class="crud-detail-value">@Model.Arac?.AracBilgi</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Müşteri Adı:</span>
                <span class="crud-detail-value">@Model.Musteri?.AdSoyad</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Musteri?.Email))
            {
                <div class="crud-detail-item">
                    <span class="crud-detail-label">Müşteri E-Posta:</span>
                    <span class="crud-detail-value">@Model.Musteri.Email</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Musteri?.Telefon))
            {
                <div class="crud-detail-item">
                    <span class="crud-detail-label">Müşteri Telefon:</span>
                    <span class="crud-detail-value">@Model.Musteri.Telefon</span>
                </div>
            }
        </div>

        <div class="crud-confirmation-actions">
            <form asp-action="Delete" method="post" style="display: contents;">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Evet, Sil
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> İptal
            </a>
        </div>
    </div>
</div>