@model OtoServisSatis.Entities.Satis

@{
    ViewData["Title"] = "Satış Ekle";
}

<h1>Satış Ekle</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="AracId" class="control-label"></label>
                <select id="aracSelect" asp-for="AracId" class="form-select" asp-items="ViewBag.AracId"></select>
            </div>
            <div class="form-group">
                <label asp-for="MusteriId" class="control-label"></label>
                <select asp-for="MusteriId" class="form-select" asp-items="ViewBag.MusteriId"></select>
            </div>
            <div class="form-group">
                <label asp-for="SatisFiyati" class="control-label"></label>
                <input id="satisFiyatiInput" asp-for="SatisFiyati" type="number" step="0.01" class="form-control" readonly style="background-color: #e9ecef;" />
                <span asp-validation-for="SatisFiyati" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SatisTarihi" class="control-label"></label>
                <input asp-for="SatisTarihi" class="form-control" />
                <span asp-validation-for="SatisTarihi" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Ekle" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const aracSelect = document.getElementById('aracSelect');
            const satisFiyatiInput = document.getElementById('satisFiyatiInput');

            function fetchAracPrice(aracId) {
                if (!aracId) {
                    satisFiyatiInput.value = '';
                    return;
                }

                fetch(`/Admin/Sales/GetAracPrice?id=${aracId}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data && data.fiyati) {
                            satisFiyatiInput.value = parseFloat(data.fiyati).toFixed(2);
                        }
                    })
                    .catch(error => console.error('Fiyat çekme hatası:', error));
            }

            aracSelect.addEventListener('change', function() {
                fetchAracPrice(this.value);
            });

            if (aracSelect.value) {
                fetchAracPrice(aracSelect.value);
            }
        });
    </script>
}