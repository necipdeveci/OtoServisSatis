@model OtoServisSatis.Entities.Satis

@{
    ViewData["Title"] = "Satış Ekle";
}

<div class="admin-form-container">
    <h1 class="admin-form-title">Yeni Satış Kaydı Ekle</h1>

    <div class="admin-form-card">
        <form asp-action="Create" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="admin-validation-summary"></div>

            <!-- Araç Seçimi -->
            <div class="admin-form-group">
                <label asp-for="AracId" class="control-label">Araç *</label>
                <select id="aracSelect" asp-for="AracId" class="form-select" asp-items="ViewBag.AracId">
                    <option value="">-- Araç Seçiniz --</option>
                </select>
                <span asp-validation-for="AracId" class="admin-validation-error"></span>
            </div>

            <!-- Müşteri Seçimi -->
            <div class="admin-form-group">
                <label asp-for="MusteriId" class="control-label">Müşteri *</label>
                <select asp-for="MusteriId" class="form-select" asp-items="ViewBag.MusteriId">
                    <option value="">-- Müşteri Seçiniz --</option>
                </select>
                <span asp-validation-for="MusteriId" class="admin-validation-error"></span>
            </div>

            <!-- Satış Fiyatı -->
            <div class="admin-form-group">
                <label asp-for="SatisFiyati" class="control-label">Satış Fiyatı (₺) *</label>
                <input id="satisFiyatiInput" asp-for="SatisFiyati" type="number" step="0.01" class="form-control" placeholder="0.00" readonly style="opacity: 0.7;" />
                <small class="text-muted d-block mt-1">Araç seçildiğinde otomatik doldurulacak</small>
                <span asp-validation-for="SatisFiyati" class="admin-validation-error"></span>
            </div>

            <!-- Satış Tarihi -->
            <div class="admin-form-group">
                <label asp-for="SatisTarihi" class="control-label">Satış Tarihi *</label>
                <input asp-for="SatisTarihi" class="form-control" type="datetime-local" />
                <span asp-validation-for="SatisTarihi" class="admin-validation-error"></span>
            </div>

            <!-- Action Buttons -->
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Satış Kaydı Ekle
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const aracSelect = document.getElementById('aracSelect');
            const satisFiyatiInput = document.getElementById('satisFiyatiInput');

            function fetchAracPrice(aracId) {
                if (!aracId) {
                    satisFiyatiInput.value = '';
                    return;
                }

                fetch(`/Admin/Sales/GetAracPrice?id=${aracId}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data && data.fiyati) {
                            satisFiyatiInput.value = parseFloat(data.fiyati).toFixed(2);
                        }
                    })
                    .catch(error => console.error('Fiyat çekme hatası:', error));
            }

            aracSelect.addEventListener('change', function() {
                fetchAracPrice(this.value);
            });

            if (aracSelect.value) {
                fetchAracPrice(aracSelect.value);
            }
        });
    </script>
}