@model OtoServisSatis.Entities.Servis

@{
    ViewData["Title"] = "Servis Kaydı Ekle";
}

<div class="admin-form-container">
    <h1 class="admin-form-title">Yeni Servis Kaydı Ekle</h1>

    <div class="admin-form-card">
        <form asp-action="Create" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="admin-validation-summary"></div>

            <!-- Araç Bilgileri Başlığı -->
            <h5 class="mt-3 mb-3" style="font-weight: 600; color: var(--bs-primary);">
                <i class="fas fa-car"></i> Araç Bilgileri
            </h5>

            <!-- Araç Plakası -->
            <div class="admin-form-group">
                <label asp-for="AracPlaka" class="control-label">Araç Plakası *</label>
                <input asp-for="AracPlaka" class="form-control" placeholder="Örn: 34ABC123" style="text-transform: uppercase;" />
                <span asp-validation-for="AracPlaka" class="admin-validation-error"></span>
            </div>

            <!-- Marka -->
            <div class="admin-form-group">
                <label asp-for="Marka" class="control-label">Marka *</label>
                <input asp-for="Marka" class="form-control" placeholder="Örn: Toyota" />
                <span asp-validation-for="Marka" class="admin-validation-error"></span>
            </div>

            <!-- Model -->
            <div class="admin-form-group">
                <label asp-for="Model" class="control-label">Model *</label>
                <input asp-for="Model" class="form-control" placeholder="Örn: Corolla" />
                <span asp-validation-for="Model" class="admin-validation-error"></span>
            </div>

            <!-- Kasa Tipi -->
            <div class="admin-form-group">
                <label asp-for="KasaTipi" class="control-label">Kasa Tipi</label>
                <input asp-for="KasaTipi" class="form-control" placeholder="Örn: Sedan" />
                <span asp-validation-for="KasaTipi" class="admin-validation-error"></span>
            </div>

            <!-- Şase No -->
            <div class="admin-form-group">
                <label asp-for="SaseNo" class="control-label">Şase No</label>
                <input asp-for="SaseNo" class="form-control" placeholder="Şase numarası..." />
                <span asp-validation-for="SaseNo" class="admin-validation-error"></span>
            </div>

            <!-- Servis Bilgileri Başlığı -->
            <h5 class="mt-4 mb-3" style="font-weight: 600; color: var(--bs-primary);">
                <i class="fas fa-wrench"></i> Servis Bilgileri
            </h5>

            <!-- Servise Geliş Tarihi -->
            <div class="admin-form-group">
                <label asp-for="ServiseGelisTarihi" class="control-label">Servise Geliş Tarihi *</label>
                <input asp-for="ServiseGelisTarihi" class="form-control" type="datetime-local" />
                <span asp-validation-for="ServiseGelisTarihi" class="admin-validation-error"></span>
            </div>

            <!-- Araç Sorunu -->
            <div class="admin-form-group">
                <label asp-for="AracSorunu" class="control-label">Araç Sorunu *</label>
                <textarea asp-for="AracSorunu" class="form-control" rows="3" placeholder="Müşteri tarafından bildirilen sorun..."></textarea>
                <span asp-validation-for="AracSorunu" class="admin-validation-error"></span>
            </div>

            <!-- Yapılan İşlemler -->
            <div class="admin-form-group">
                <label class="control-label">Yapılan İşlemler</label>
                <small class="d-block text-muted mb-2">İşlemler dinamik olarak eklenebilir</small>
                <div id="islemlerContainer">
                    <div class="input-group mb-2">
                        <input type="text" class="form-control islem-input" placeholder="İşlem ekleyin..." />
                        <button type="button" class="btn btn-success btn-add-islem" title="Yeni işlem ekle">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>
                <input type="hidden" asp-for="YapilanIslemler" id="yapilanIslemlerHidden" />
                <span asp-validation-for="YapilanIslemler" class="admin-validation-error"></span>
            </div>

            <!-- Servistten Çıkış Tarihi -->
            <div class="admin-form-group">
                <label asp-for="ServistenCikisTarihi" class="control-label">Servisten Çıkış Tarihi</label>
                <input asp-for="ServistenCikisTarihi" class="form-control" type="datetime-local" />
                <span asp-validation-for="ServistenCikisTarihi" class="admin-validation-error"></span>
            </div>

            <!-- Servis Ücreti -->
            <div class="admin-form-group">
                <label asp-for="ServisUcreti" class="control-label">Servis Ücreti (₺)</label>
                <input asp-for="ServisUcreti" class="form-control" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="ServisUcreti" class="admin-validation-error"></span>
            </div>

            <!-- Garanti Kapsamında Mı -->
            <div class="admin-form-group">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="GarantiKapsamindaMi" />
                    <label class="form-check-label" for="GarantiKapsamindaMi">
                        Garanti Kapsamında Mı?
                    </label>
                </div>
            </div>

            <!-- Notlar -->
            <div class="admin-form-group">
                <label asp-for="Notlar" class="control-label">Notlar</label>
                <textarea asp-for="Notlar" class="form-control" rows="2" placeholder="Ek notlar..."></textarea>
                <span asp-validation-for="Notlar" class="admin-validation-error"></span>
            </div>

            <!-- Action Buttons -->
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Servis Kaydı Ekle
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Yeni işlem input ekle
            $(document).on('click', '.btn-add-islem', function() {
                var inputValue = $(this).siblings('.islem-input').val().trim();
                var newInput = $(`
                    <div class="input-group mb-2">
                        <input type="text" class="form-control islem-input" placeholder="İşlem ekleyin..." value="${inputValue}" />
                        <button type="button" class="btn btn-danger btn-remove-islem" title="Kaldır">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `);
                $('#islemlerContainer').append(newInput);
                $(this).siblings('.islem-input').val('').focus();
            });

            // İşlem input kaldır
            $(document).on('click', '.btn-remove-islem', function() {
                $(this).closest('.input-group').remove();
            });

            // Form submit öncesi verileri CSV formatına çevir
            $('form').on('submit', function() {
                var islemler = [];
                $('.islem-input').each(function() {
                    var deger = $(this).val().trim();
                    if (deger) {
                        islemler.push(deger);
                    }
                });
                $('#yapilanIslemlerHidden').val(islemler.join(','));
            });
        });
    </script>
}