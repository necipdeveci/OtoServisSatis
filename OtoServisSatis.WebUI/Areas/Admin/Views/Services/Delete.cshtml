@model OtoServisSatis.Entities.Servis

@{
    ViewData["Title"] = "Servis Kaydını Sil";
}

<div class="crud-container">
    <div class="crud-page-header">
        <h1 class="crud-page-title">Servis Kaydını Sil</h1>
        <p class="crud-page-description">Bu işlem geri alınamaz</p>
        <div class="crud-divider"></div>
    </div>

    <div class="crud-detail-card">
        <div class="crud-confirmation-alert">
            <h4><i class="fas fa-exclamation-triangle"></i> Onay Gerekli</h4>
            <p>Bu servis kaydını silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
        </div>

        <div class="crud-detail-header">
            <h5 class="crud-detail-title">Silinecek Kayıt Bilgileri</h5>
        </div>

        <div class="crud-detail-grid">
            <div class="crud-detail-item">
                <span class="crud-detail-label">Araç Plakası:</span>
                <span class="crud-detail-value">@Model.AracPlaka</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Araç:</span>
                <span class="crud-detail-value">@Model.Marka @Model.Model @(string.IsNullOrEmpty(Model.KasaTipi) ? "" : $"({Model.KasaTipi})")</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Giriş Tarihi:</span>
                <span class="crud-detail-value">@Model.ServiseGelisTarihi.ToString("dd.MM.yyyy HH:mm")</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Çıkış Tarihi:</span>
                <span class="crud-detail-value">@(Model.ServistenCikisTarihi != default ? Model.ServistenCikisTarihi.ToString("dd.MM.yyyy HH:mm") : "-")</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Sorunu:</span>
                <span class="crud-detail-value">@Model.AracSorunu</span>
            </div>

            <div class="crud-detail-item">
                <span class="crud-detail-label">Servis Ücreti:</span>
                <span class="crud-detail-value">₺@Model.ServisUcreti.ToString("N2")</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.YapilanIslemler))
            {
                <div class="crud-detail-item">
                    <span class="crud-detail-label">Yapılan İşlemler:</span>
                    <span class="crud-detail-value">@Model.YapilanIslemler</span>
                </div>
            }

            <div class="crud-detail-item">
                <span class="crud-detail-label">Garanti:</span>
                <span class="crud-detail-value">@(Model.GarantiKapsamindaMi ? "Garanti Kapsamında" : "Garanti Dışı")</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notlar))
            {
                <div class="crud-detail-item">
                    <span class="crud-detail-label">Notlar:</span>
                    <span class="crud-detail-value">@Model.Notlar</span>
                </div>
            }
        </div>

        <div class="crud-confirmation-actions">
            <form asp-action="Delete" method="post" style="display: contents;">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Evet, Sil
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> İptal
            </a>
        </div>
    </div>
</div>