@model OtoServisSatis.Entities.Slider

@{
    ViewData["Title"] = "Slide Ekle";
}

<div class="admin-form-container">
    <h1 class="admin-form-title">Yeni Slide Ekle</h1>

    <div class="admin-form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="admin-validation-summary"></div>

            <!-- Başlık -->
            <div class="admin-form-group">
                <label asp-for="Baslik" class="control-label">Başlık *</label>
                <input asp-for="Baslik" class="form-control" placeholder="Slide başlığı..." />
                <span asp-validation-for="Baslik" class="admin-validation-error"></span>
            </div>

            <!-- Açıklama -->
            <div class="admin-form-group">
                <label asp-for="Aciklama" class="control-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control" rows="3" placeholder="Slide açıklaması..."></textarea>
                <span asp-validation-for="Aciklama" class="admin-validation-error"></span>
            </div>

            <!-- Resim -->
            <div class="admin-form-group">
                <label asp-for="Resim" class="control-label">Resim *</label>
                <small class="d-block text-muted mb-2">Desteklenen formatlar: JPG, PNG (Önerilen boyut: 1920x600px)</small>
                <input asp-for="Resim" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="Resim" class="admin-validation-error"></span>
            </div>

            <!-- Link -->
            <div class="admin-form-group">
                <label asp-for="Link" class="control-label">Link</label>
                <input asp-for="Link" class="form-control" placeholder="https://example.com" type="url" />
                <span asp-validation-for="Link" class="admin-validation-error"></span>
            </div>

            <!-- Action Buttons -->
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Slide Ekle
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}